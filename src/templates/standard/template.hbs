<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invoice {{invoice.number}}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      font-size: 13px;
      color: #1a1a2e;
      background: #fff;
      padding: 32px 40px;
    }

    /* ── Header ── */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 36px;
      padding-bottom: 24px;
      border-bottom: 3px solid #2563eb;
    }

    .brand h1 {
      font-size: 28px;
      font-weight: 700;
      color: #2563eb;
      letter-spacing: -0.5px;
    }

    .brand p {
      color: #64748b;
      font-size: 12px;
      margin-top: 2px;
    }

    .invoice-meta {
      text-align: right;
    }

    .invoice-meta .label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: #94a3b8;
    }

    .invoice-meta .number {
      font-size: 20px;
      font-weight: 700;
      color: #1e293b;
    }

    .invoice-meta .dates {
      margin-top: 6px;
      font-size: 12px;
      color: #475569;
      line-height: 1.6;
    }

    /* ── Parties ── */
    .parties {
      display: flex;
      gap: 40px;
      margin-bottom: 32px;
    }

    .party {
      flex: 1;
      background: #f8fafc;
      border-radius: 8px;
      padding: 16px 20px;
    }

    .party-role {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #2563eb;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .party h3 {
      font-size: 14px;
      font-weight: 600;
      color: #1e293b;
      margin-bottom: 4px;
    }

    .party p {
      font-size: 12px;
      color: #64748b;
      line-height: 1.6;
    }

    /* ── Items table ── */
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 24px;
    }

    thead tr {
      background: #2563eb;
      color: #fff;
    }

    thead th {
      padding: 10px 12px;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      font-weight: 600;
      text-align: left;
    }

    thead th.right { text-align: right; }

    tbody tr:nth-child(even) { background: #f8fafc; }

    tbody td {
      padding: 10px 12px;
      font-size: 12px;
      color: #334155;
      border-bottom: 1px solid #e2e8f0;
    }

    tbody td.right { text-align: right; }

    /* ── Totals ── */
    .totals-wrapper {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 32px;
    }

    .totals {
      width: 280px;
    }

    .totals-row {
      display: flex;
      justify-content: space-between;
      padding: 6px 0;
      font-size: 13px;
      color: #475569;
      border-bottom: 1px solid #e2e8f0;
    }

    .totals-row.grand {
      font-size: 16px;
      font-weight: 700;
      color: #1e293b;
      border-bottom: none;
      padding-top: 10px;
    }

    /* ── Notes ── */
    .notes {
      background: #eff6ff;
      border-left: 4px solid #2563eb;
      border-radius: 4px;
      padding: 12px 16px;
      font-size: 12px;
      color: #475569;
      margin-bottom: 32px;
    }

    .notes strong {
      display: block;
      color: #1e293b;
      margin-bottom: 4px;
    }

    /* ── Footer ── */
    .footer {
      text-align: center;
      font-size: 11px;
      color: #94a3b8;
      padding-top: 16px;
      border-top: 1px solid #e2e8f0;
    }
  </style>
</head>
<body>

  <div class="header">
    <div class="brand">
      <h1>{{seller.name}}</h1>
      <p>{{seller.address}}, {{seller.city}}, {{seller.country}}</p>
      {{#if seller.taxId}}<p>Tax ID: {{seller.taxId}}</p>{{/if}}
      {{#if seller.email}}<p>{{seller.email}}</p>{{/if}}
    </div>
    <div class="invoice-meta">
      <div class="label">Invoice</div>
      <div class="number">{{invoice.number}}</div>
      <div class="dates">
        <div>Issued: {{formatDate invoice.date}}</div>
        <div>Due: {{formatDate invoice.dueDate}}</div>
      </div>
    </div>
  </div>

  <div class="parties">
    <div class="party">
      <div class="party-role">From</div>
      <h3>{{seller.name}}</h3>
      <p>{{seller.address}}</p>
      <p>{{seller.city}}, {{seller.country}}</p>
      {{#if seller.taxId}}<p>Tax ID: {{seller.taxId}}</p>{{/if}}
    </div>
    <div class="party">
      <div class="party-role">Bill To</div>
      <h3>{{buyer.name}}</h3>
      <p>{{buyer.address}}</p>
      <p>{{buyer.city}}, {{buyer.country}}</p>
      {{#if buyer.taxId}}<p>Tax ID: {{buyer.taxId}}</p>{{/if}}
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>Description</th>
        <th class="right">Qty</th>
        <th class="right">Unit Price</th>
        <th class="right">VAT %</th>
        <th class="right">VAT Amt</th>
        <th class="right">Total</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
      <tr>
        <td>{{description}}</td>
        <td class="right">{{quantity}}</td>
        <td class="right">{{formatMoney unitPrice ../currencySymbol}}</td>
        <td class="right">{{vatRate}}%</td>
        <td class="right">{{formatMoney vatAmount ../currencySymbol}}</td>
        <td class="right">{{formatMoney lineTotalWithVat ../currencySymbol}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <div class="totals-wrapper">
    <div class="totals">
      <div class="totals-row">
        <span>Subtotal</span>
        <span>{{formatMoney totals.subtotal currencySymbol}}</span>
      </div>
      <div class="totals-row">
        <span>VAT</span>
        <span>{{formatMoney totals.totalVat currencySymbol}}</span>
      </div>
      <div class="totals-row grand">
        <span>Total Due</span>
        <span>{{formatMoney totals.grandTotal currencySymbol}}</span>
      </div>
    </div>
  </div>

  {{#if notes}}
  <div class="notes">
    <strong>Notes</strong>
    {{notes}}
  </div>
  {{/if}}

  <div class="footer">
    Thank you for your business · {{seller.name}} · {{invoice.number}}
  </div>

</body>
</html>
